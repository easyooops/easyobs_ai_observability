# =============================================================================
# EasyObs production deployment — single env file
#
# 단일 노드(docker-compose.app.yml) 와 클러스터(docker-compose.cluster.yml)
# 양쪽 모두 이 .env 한 파일로 동작한다.
# =============================================================================

# ---- Image tags -------------------------------------------------------------

EASYOBS_API_IMAGE=easyobs/api:0.2.0
EASYOBS_WEB_IMAGE=easyobs/web:0.2.0
POSTGRES_IMAGE=postgres:16
NGINX_IMAGE=nginx:1.27-alpine

# ---- Host port bindings -----------------------------------------------------
# 단일 노드 (docker-compose.app.yml) 는 호스트에 바로 노출.
# 클러스터 (docker-compose.cluster.yml) 는 nginx 만 호스트로 노출.

EASYOBS_API_HOST_PORT=8787
EASYOBS_WEB_HOST_PORT=3000
EASYOBS_LB_HTTP_PORT=80

# ---- Postgres ---------------------------------------------------------------
# 클러스터 모드에서는 RDS / 외부 Postgres 사용을 권장. 그 경우
# DATABASE_URL 만 외부 주소로 바꾸고 deps 컴포즈는 띄우지 않으면 된다.

POSTGRES_USER=easyobs
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=easyobs

# ---- EasyObs API ------------------------------------------------------------
# DATABASE_URL: SQLite 가 아닌 Postgres 로 강제 설정 (수평 확장 전제).
# JWT_SECRET: 모든 인스턴스가 동일 값을 공유해야 세션이 깨지지 않음.
#   `openssl rand -hex 32` 또는 `python -c "import secrets;print(secrets.token_hex(32))"`

EASYOBS_DATABASE_URL=postgresql+asyncpg://easyobs:change-me-postgres@postgres:5432/easyobs
EASYOBS_JWT_SECRET=replace-with-32-byte-hex-secret
EASYOBS_JWT_TTL_HOURS=12

# ---- 서버 동작 ---------------------------------------------------------------

EASYOBS_API_HOST=0.0.0.0
EASYOBS_API_PORT=8787
EASYOBS_DATA_DIR=/var/lib/easyobs
EASYOBS_LOG_LEVEL=INFO
EASYOBS_LOG_FORMAT=json
EASYOBS_LOG_REQUEST_BODY=false
EASYOBS_PRICING_SOURCE=auto

# CORS — Web 콘솔이 같은 호스트의 다른 포트에서 도는 경우(=대부분)
# 자동 정규식으로 localhost 가 허용되니, 외부 도메인을 쓰면 여기에 추가.
EASYOBS_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---- 평가(Quality) ----------------------------------------------------------

EASYOBS_EVAL_ENABLED=true
EASYOBS_EVAL_AUTO_RULE_ON_INGEST=true

# ---- Alarm (threshold alerting) ---------------------------------------------
# !! 클러스터 모드 주의 !!
# Alarm evaluator 는 60초 폴링하는 in-process loop 다.
# API 컨테이너가 N대 동시에 ALARM_ENABLED=true 면 동일 알람이 N번 발송된다.
# 클러스터에서는 워커 컨테이너는 EASYOBS_ALARM_ENABLED=false 로,
# leader 1대만 EASYOBS_ALARM_ENABLED=true 로 둘 것.

EASYOBS_ALARM_ENABLED=true
EASYOBS_ALARM_EVAL_INTERVAL_SECONDS=60

# ---- 데모 / Mock 데이터 ------------------------------------------------------
# 운영에서는 모두 false 권장 (실데이터 보호).

EASYOBS_SEED_MOCK_DATA=false
EASYOBS_SEED_MOCK_LIVE=false

# ---- 클러스터 워커 수 (cluster compose 전용) --------------------------------
# docker-compose.cluster.yml 의 deploy.replicas 를 .env 로 빼두기.

EASYOBS_API_REPLICAS=2

# ---- 프론트엔드 -------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
