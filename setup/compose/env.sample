# =============================================================================
# EasyObs production deployment — single env file
#
# 단일 노드(docker-compose.app.yml) 와 클러스터(docker-compose.cluster.yml)
# 양쪽 모두 이 .env 한 파일로 동작한다.
# =============================================================================

# ---- Image tags -------------------------------------------------------------

EASYOBS_API_IMAGE=easyobs/api:0.2.0
EASYOBS_WEB_IMAGE=easyobs/web:0.2.0
POSTGRES_IMAGE=postgres:16
NGINX_IMAGE=nginx:1.27-alpine

# ---- Host port bindings -----------------------------------------------------
# 단일 노드 (docker-compose.app.yml) 는 호스트에 바로 노출.
# 클러스터 (docker-compose.cluster.yml) 는 nginx 만 호스트로 노출.

EASYOBS_API_HOST_PORT=8787
EASYOBS_WEB_HOST_PORT=3000
EASYOBS_LB_HTTP_PORT=80

# ---- Postgres ---------------------------------------------------------------
# 클러스터 모드에서는 RDS / 외부 Postgres 사용을 권장. 그 경우
# DATABASE_URL 만 외부 주소로 바꾸고 deps 컴포즈는 띄우지 않으면 된다.

POSTGRES_USER=easyobs
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=easyobs

# ---- EasyObs API ------------------------------------------------------------
# DATABASE_URL: SQLite 가 아닌 Postgres 로 강제 설정 (수평 확장 전제).
# JWT_SECRET: 모든 인스턴스가 동일 값을 공유해야 세션이 깨지지 않음.
#   `openssl rand -hex 32` 또는 `python -c "import secrets;print(secrets.token_hex(32))"`

EASYOBS_DATABASE_URL=postgresql+asyncpg://easyobs:change-me-postgres@postgres:5432/easyobs
EASYOBS_JWT_SECRET=replace-with-32-byte-hex-secret
EASYOBS_JWT_TTL_HOURS=12

# ---- 서버 동작 ---------------------------------------------------------------

EASYOBS_API_HOST=0.0.0.0
EASYOBS_API_PORT=8787
EASYOBS_DATA_DIR=/var/lib/easyobs
EASYOBS_LOG_LEVEL=INFO
EASYOBS_LOG_FORMAT=json
EASYOBS_LOG_REQUEST_BODY=false
EASYOBS_PRICING_SOURCE=auto

# ---- 스토리지 & 쿼리 엔진 ---------------------------------------------------
# storage_format: parquet(권장) / ndjson(레거시)
# query_engine:   duckdb(권장, parquet 필수) / legacy(Python 루프)

EASYOBS_STORAGE_FORMAT=parquet
EASYOBS_QUERY_ENGINE=duckdb

# ---- 클라우드 Blob 스토리지 (S3 / Azure / GCS) --------------------------------
# blob provider 는 UI(Settings)에서 설정하거나, app_settings.json 으로 사전 구성.
# 아래 환경 변수는 docker-compose 에서 컨테이너에 전달할 값.
# 로컬 파일시스템 사용 시 모두 비워두면 DATA_DIR/blob 경로에 저장.

# -- S3
#EASYOBS_BLOB_PROVIDER=s3
#EASYOBS_BLOB_BUCKET=my-easyobs-traces
#EASYOBS_BLOB_PREFIX=traces/
#EASYOBS_BLOB_REGION=ap-northeast-2
#EASYOBS_BLOB_S3_ACCESS_KEY_ID=
#EASYOBS_BLOB_S3_SECRET_ACCESS_KEY=

# -- Azure Blob Storage
#EASYOBS_BLOB_PROVIDER=azure
#EASYOBS_BLOB_AZURE_ACCOUNT_NAME=myaccount
#EASYOBS_BLOB_AZURE_ACCOUNT_KEY=
#EASYOBS_BLOB_AZURE_CONTAINER=easyobs-traces

# -- Google Cloud Storage
#EASYOBS_BLOB_PROVIDER=gcs
#EASYOBS_BLOB_BUCKET=my-easyobs-traces
#EASYOBS_BLOB_GCS_SERVICE_ACCOUNT_JSON=/run/secrets/gcs-key.json

# -- Hybrid (Local Parquet + S3 Archive)
# 로컬 Blob Store에 최근 7일 실시간 데이터를 적재하고,
# S3에 전체 데이터를 아카이브합니다. 기간 선택 시:
#   - 1h/6h/24h/7d 프리셋 → 로컬 Blob Store에서 빠르게 쿼리
#   - custom 커스텀 기간(7일 초과) → S3 아카이브에서 쿼리
#EASYOBS_BLOB_PROVIDER=hybrid
#EASYOBS_BLOB_BUCKET=my-easyobs-archive
#EASYOBS_BLOB_PREFIX=traces
#EASYOBS_BLOB_REGION=ap-northeast-2
#EASYOBS_BLOB_S3_ACCESS_KEY_ID=
#EASYOBS_BLOB_S3_SECRET_ACCESS_KEY=
#EASYOBS_BLOB_HOT_RETENTION_DAYS=7

# CORS — Web 콘솔이 같은 호스트의 다른 포트에서 도는 경우(=대부분)
# 자동 정규식으로 localhost 가 허용되니, 외부 도메인을 쓰면 여기에 추가.
EASYOBS_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---- 평가(Quality) ----------------------------------------------------------

EASYOBS_EVAL_ENABLED=true
EASYOBS_EVAL_AUTO_RULE_ON_INGEST=true

# ---- Alarm (threshold alerting) ---------------------------------------------
# !! 클러스터 모드 주의 !!
# Alarm evaluator 는 60초 폴링하는 in-process loop 다.
# API 컨테이너가 N대 동시에 ALARM_ENABLED=true 면 동일 알람이 N번 발송된다.
# 클러스터에서는 워커 컨테이너는 EASYOBS_ALARM_ENABLED=false 로,
# leader 1대만 EASYOBS_ALARM_ENABLED=true 로 둘 것.

EASYOBS_ALARM_ENABLED=true
EASYOBS_ALARM_EVAL_INTERVAL_SECONDS=60

# ---- 데모 / Mock 데이터 ------------------------------------------------------
# 운영에서는 모두 false 권장 (실데이터 보호).

EASYOBS_SEED_MOCK_DATA=false
EASYOBS_SEED_MOCK_LIVE=false

# ---- 클러스터 워커 수 (cluster compose 전용) --------------------------------
# docker-compose.cluster.yml 의 deploy.replicas 를 .env 로 빼두기.

EASYOBS_API_REPLICAS=2

# ---- LLM Judge (Quality Evaluation) ----------------------------------------
# Judge Models 는 UI(Settings > Judge Models)에서 추가하거나 API 로 등록.
# 각 provider 가 사용하는 API 키를 아래 환경 변수로 설정.
# 키가 없으면 해당 provider 는 mock(결정론적 해시 기반)으로 fallback.

# -- OpenAI
#OPENAI_API_KEY=sk-...

# -- Anthropic (Claude)
#ANTHROPIC_API_KEY=sk-ant-...

# -- Google AI Studio (Gemini)
#GOOGLE_API_KEY=AIza...

# -- Google Vertex AI (GCP)
# JSON 키 파일 경로. Docker 에서는 시크릿 마운트 후 컨테이너 내 경로 지정.
#GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-vertex-key.json

# -- Azure OpenAI
#AZURE_OPENAI_API_KEY=...
# endpoint / deployment 은 Judge Model 등록 시 connection 필드로 설정.

# -- AWS Bedrock
# EC2 에 IAM Instance Profile (bedrock:InvokeModel 권한) 이 있으면
# AWS_PROFILE / ACCESS_KEY 없이도 boto3 가 자동 인증.
# 로컬/docker 에서는 named profile 또는 explicit key 지정:
#AWS_PROFILE=default
#AWS_ACCESS_KEY_ID=AKIA...
#AWS_SECRET_ACCESS_KEY=...
#AWS_DEFAULT_REGION=us-east-1

# -- On-Premise (vLLM / LiteLLM 등 OpenAI-compatible)
# base_url 은 Judge Model 등록 시 connection.base_url 로 설정.
# API 키가 필요하면 OPENAI_API_KEY 재사용 또는 connection.api_key_env 지정.

# ---- 프론트엔드 -------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
