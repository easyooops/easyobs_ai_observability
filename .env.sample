# =============================================================================
# EasyObs API server configuration.
#
# Every value is optional — defaults live in src/easyobs/settings.py.
# Override here for local dev, or via real environment variables in your
# container / Lambda runtime.
# =============================================================================

# ---- Storage ---------------------------------------------------------------

# Directory that holds the SQLite catalog, JWT signing secret, and the
# trace blob store. Wiped by `easyobs reset-data`. Use an absolute path or
# a mounted volume in production.
EASYOBS_DATA_DIR=./data

# Async SQLAlchemy URL. Leave blank to derive `<EASYOBS_DATA_DIR>/catalog.sqlite3`
# automatically. Override to point at Postgres in production, e.g.
# `postgresql+asyncpg://user:pw@host:5432/easyobs`.
# EASYOBS_DATABASE_URL=

# Storage format for trace span blobs.
#   parquet — columnar format, DuckDB query acceleration, recommended for all new deployments
#   ndjson  — legacy JSON-lines format (no DuckDB), for backward compat only
EASYOBS_STORAGE_FORMAT=parquet

# Analytics query engine.
#   duckdb — vectorized SQL over Parquet, sub-second aggregation at any scale
#   legacy — original Python-loop analytics (small deployments or when pyarrow/duckdb not installed)
EASYOBS_QUERY_ENGINE=duckdb

# ---- HTTP server -----------------------------------------------------------

# Bind address for the FastAPI process. Use 0.0.0.0 inside containers.
EASYOBS_API_HOST=127.0.0.1
# TCP port for the API + OTLP/HTTP ingest endpoint.
EASYOBS_API_PORT=8787
# Comma-separated list of allowed browser origins for the Next.js console.
# Localhost variants are also matched by a regex in the app, so you only
# need to extend this when serving the console from a non-local hostname.
EASYOBS_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---- Pricing ---------------------------------------------------------------

# Source for the per-token LLM price table used to enrich `o.price` on
# ingest. `auto` prefers `tokencost`, then `litellm`, then a small built-in
# fallback table.
EASYOBS_PRICING_SOURCE=auto

# ---- Authentication --------------------------------------------------------

# HS256 signing key for session JWTs. Leave blank for local dev — the
# server generates a key on first boot and persists it under
# `<EASYOBS_DATA_DIR>/jwt.secret`. In production set this to a strong
# random value (e.g. `openssl rand -hex 32`) and keep it out of version
# control.
EASYOBS_JWT_SECRET=
# JWT lifetime in hours. Sessions silently expire after this; users sign
# back in to get a fresh token.
EASYOBS_JWT_TTL_HOURS=12

# ---- Logging / operational visibility --------------------------------------

# Root level for the `easyobs.*` and `uvicorn` loggers.
# DEBUG | INFO | WARNING | ERROR
EASYOBS_LOG_LEVEL=INFO
# `console` = single-line human-readable records (good for local dev and
# `docker logs`). `json` = one JSON object per line — picked up as-is by
# CloudWatch Logs (awslogs / fluent-bit), Loki, GCP Cloud Logging, etc.
EASYOBS_LOG_FORMAT=console
# Optional file path that mirrors every log record in addition to stdout.
# Leave unset on container / serverless runtimes so the platform owns log
# capture (CloudWatch, Stackdriver, ...).
# EASYOBS_LOG_FILE=./data/api.log
# When true, the request-logging middleware also records JSON request
# payloads (capped to 4 KB). Off by default to avoid leaking PII / secrets
# into your log aggregator.
EASYOBS_LOG_REQUEST_BODY=false

# ---- First-boot mock / demo data -------------------------------------------

# When `true`, on the very first boot the API populates the default
# `administrator` organization with a `demo` service and N synthetic OTLP
# traces so you can explore the full UI (Tracing, Sessions, Metrics)
# without having to sign up, mint a token, and run a seed script.
#
# Idempotent and safe: the seeder skips silently if any trace already
# exists in the catalog, so it cannot overwrite real data. To re-seed,
# run `easyobs reset-data --force --yes` first.
#
# Default: false. Turn on for MVP demos and short-lived test environments.
EASYOBS_SEED_MOCK_DATA=true
# Number of synthetic traces to generate when `EASYOBS_SEED_MOCK_DATA=true`.
EASYOBS_SEED_MOCK_TRACES=1000
# Time window the synthetic traces are spread over, in hours. 240h (= 10 days)
# spreads traces across roughly a fortnight so long-range filters and trend
# charts have enough data points. Distribution is biased toward "now"
# (triangular, mode=0) so the most recent buckets stay populated even
# with a wide window.
EASYOBS_SEED_MOCK_WINDOW_HOURS=240

# When true, the API also runs a background task that drips one synthetic
# trace into the demo service every ~`SEED_MOCK_LIVE_INTERVAL_SEC` while
# the server is up. Without this the seeder only fills *history* and the
# 'Last 1h / 6h' workspace windows go empty after the first hour.
# Requires `SEED_MOCK_DATA=true`; no-op otherwise.
EASYOBS_SEED_MOCK_LIVE=false
# Average cadence between synthetic traces (seconds). Actual delay is
# jittered ±30% so the chart doesn't look like a perfect comb.
EASYOBS_SEED_MOCK_LIVE_INTERVAL_SEC=20
# Each synthetic live trace's start time is jittered backwards by up to
# this many seconds from `now()` to avoid identical nanosecond stamps.
EASYOBS_SEED_MOCK_LIVE_BURST_WINDOW_SEC=10

# ---- Threshold alerting (Alarms) -------------------------------------------

# Master switch for the Alarms module. When false the API hides every
# /v1/organizations/.../alarms endpoint and the periodic evaluator is not
# started — leave on for the default workflow.
EASYOBS_ALARM_ENABLED=true
# Cadence for the in-process alarm evaluator (seconds). Lower values mean
# faster firing latency at the cost of one extra DB sweep per tick.
EASYOBS_ALARM_EVAL_INTERVAL_SECONDS=60

# ---- LLM Judge Provider Keys -----------------------------------------------
# Judge Models 는 UI (Settings > Judge Models) 또는 API 로 등록.
# 각 provider 가 아래 환경 변수에서 API 키를 읽으며, 미설정 시 mock fallback.

# -- OpenAI
#OPENAI_API_KEY=sk-...

# -- Anthropic (Claude)
#ANTHROPIC_API_KEY=sk-ant-...

# -- Google AI Studio (Gemini)
#GOOGLE_API_KEY=AIza...

# -- Google Vertex AI
#GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# -- Azure OpenAI
#AZURE_OPENAI_API_KEY=...

# -- AWS Bedrock
# EC2 Instance Profile(bedrock:InvokeModel) 이 있으면 키 없이 자동 인증됨.
# 로컬에서는 named profile 또는 explicit key 사용:
AWS_PROFILE=default
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_DEFAULT_REGION=us-east-1
